// ─── MÓDULO BOOKINGS (Multi-agenda) ──────────────────────────────────────────

model Team {
  id               String               @id @default(uuid())
  userId           String               @unique
  name             String
  description      String?
  timezone         String               @default("America/Bogota")
  isActive         Boolean              @default(true)
  minNoticeMinutes Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  members          TeamMember[]
  services         TeamService[]
  appointments     BookingAppointment[]

  @@map("teams")
}

model TeamMember {
  id               String                   @id @default(uuid())
  teamId           String
  name             String
  bio              String?
  photo            String?
  color            String?
  isActive         Boolean                  @default(true)
  defaultDuration  Int                      @default(30)
  meetingLink      String?
  minNoticeMinutes Int                      @default(0)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  team             Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  availability     TeamMemberAvailability[]
  services         TeamMemberService[]
  appointments     BookingAppointment[]

  @@index([teamId])
  @@map("team_members")
}

model TeamMemberAvailability {
  id           String     @id @default(uuid())
  teamMemberId String
  dayOfWeek    Int
  startTime    String
  endTime      String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@unique([teamMemberId, dayOfWeek, startTime, endTime])
  @@index([teamMemberId])
  @@map("team_member_availability")
}

model TeamService {
  id           String               @id @default(uuid())
  teamId       String
  name         String
  description  String?
  duration     Int
  messageText     String?
  remindersConfig Json?
  color           String?
  isActive        Boolean              @default(true)
  order        Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  team         Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members      TeamMemberService[]
  appointments BookingAppointment[]

  @@index([teamId])
  @@map("team_services")
}

model TeamMemberService {
  teamMemberId  String
  teamServiceId String
  teamMember    TeamMember  @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  teamService   TeamService @relation(fields: [teamServiceId], references: [id], onDelete: Cascade)

  @@id([teamMemberId, teamServiceId])
  @@map("team_member_services")
}

model BookingAppointment {
  id            String            @id @default(uuid())
  teamId        String
  teamMemberId  String
  teamServiceId String
  clientName    String
  clientPhone   String
  startTime     DateTime
  endTime       DateTime
  timezone      String
  status        AppointmentStatus @default(PENDIENTE)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  team          Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamMember    TeamMember        @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  teamService   TeamService       @relation(fields: [teamServiceId], references: [id])

  @@index([teamId, startTime])
  @@index([teamMemberId, startTime])
  @@index([teamServiceId])
  @@map("booking_appointments")
}

// ─────────────────────────────────────────────────────────────────────────────

model BaileysContact {
  id           String           @id @default(cuid())
  instanceName String
  remoteJid    String
  pushName     String?
  phoneNumber  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  messages     BaileysMessage[]

  @@unique([instanceName, remoteJid])
  @@index([instanceName])
  @@map("baileys_contacts")
}

model BaileysMessage {
  id           String         @id @default(cuid())
  instanceName String
  remoteJid    String
  messageId    String
  fromMe       Boolean        @default(false)
  body         String?
  type         String         @default("conversation")
  mediaUrl     String?
  timestamp    DateTime
  status       String         @default("sent")
  createdAt    DateTime       @default(now())
  contact      BaileysContact @relation(fields: [instanceName, remoteJid], references: [instanceName, remoteJid], onDelete: Cascade)

  @@unique([instanceName, messageId])
  @@index([instanceName, remoteJid, timestamp])
  @@index([instanceName, timestamp])
  @@map("baileys_messages")
}

// ─── MÓDULO FORMULARIOS DINÁMICOS ────────────────────────────────────────────

enum FormFieldType {
  text
  textarea
  select
  checkbox
  file
  number
  date
  email
  phone
  time
  url
  money
  multiselect
  radio
}

enum FormSubmissionSyncStatus {
  PENDING
  SYNCED
  ERROR
}

model Form {
  id                 String           @id @default(uuid())
  userId             String
  title              String
  slug               String
  publicSlug         String?          @unique
  description        String?
  sheetsUrl          String?
  isActive           Boolean          @default(true)
  whatsappEnabled    Boolean          @default(false)
  whatsappNumber     String?
  whatsappMessage    String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fields             FormField[]
  submissions        FormSubmission[]

  @@unique([userId, slug])
  @@index([userId])
  @@map("forms")
}

model FormField {
  id          String        @id @default(uuid())
  formId      String
  label       String
  type        FormFieldType @default(text)
  placeholder String?
  required    Boolean       @default(false)
  order       Int           @default(0)
  options     Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  form        Form          @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, order])
  @@map("form_fields")
}

model FormSubmission {
  id         String                   @id @default(uuid())
  formId     String
  data       Json
  syncStatus FormSubmissionSyncStatus @default(PENDING)
  syncedAt   DateTime?
  syncError  String?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  form       Form                     @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, createdAt])
  @@index([syncStatus])
  @@map("form_submissions")
}
