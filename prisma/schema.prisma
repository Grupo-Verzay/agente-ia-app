// Configura qué flujo se dispara automáticamente al cambiar a cada estado
model LeadStatusWorkflowConfig {
  id         String     @id @default(uuid())
  userId     String
  leadStatus LeadStatus
  workflowId String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([userId, leadStatus])
  @@map("lead_status_workflow_config")
}

// Historial de flujos disparados por sesión y estado — evita re-disparar el mismo estado
model LeadStatusWorkflowExecution {
  id         String     @id @default(uuid())
  sessionId  Int
  userId     String
  leadStatus LeadStatus
  workflowId String
  executedAt DateTime   @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, leadStatus])
  @@index([sessionId])
  @@map("lead_status_workflow_execution")
}

