generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String?  @map("refresh_token")
  accessToken       String?  @map("access_token")
  expiresAt         Int?     @map("expires_at")
  tokenType         String?  @map("token_type")
  scope             String?
  idToken           String?  @map("id_token")
  sessionState      String?  @map("session_state")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model AgentPrompt {
  id                  String                @id @default(uuid()) @db.Uuid
  userId              String
  agentId             String?
  status              PromptStatus          @default(draft)
  version             Int                   @default(1)
  sections            Json
  promptText          String
  businessName        String?
  businessSector      String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentPromptRevision AgentPromptRevision[]

  @@index([agentId])
  @@index([businessName])
  @@index([businessSector])
  @@index([sections], type: Gin)
  @@index([status])
  @@index([userId])
}

model AntifloodBlock {
  id           Int      @id @default(autoincrement())
  remoteJid    String
  instanceName String
  blockedUntil DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([remoteJid, instanceName])
  @@index([blockedUntil])
}

model AgentPromptRevision {
  id                 String      @id @default(uuid()) @db.Uuid
  promptId           String      @db.Uuid
  revisionNumber     Int
  sectionsSnapshot   Json
  promptTextSnapshot String
  publishedBy        String
  publishedAt        DateTime    @default(now())
  notes              String?
  agentPrompt        AgentPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  user               User        @relation(fields: [publishedBy], references: [id], onDelete: Cascade)

  @@unique([promptId, revisionNumber])
  @@index([publishedAt])
}

model ApiKey {
  id        String   @id @default(uuid())
  url       String
  key       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model Appointment {
  id         String            @id @default(uuid())
  userId     String
  sessionId  Int
  clientName String?
  startTime  DateTime
  endTime    DateTime
  timezone   String
  status     AppointmentStatus @default(PENDIENTE)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  serviceId  String?
  service   Service?          @relation(fields: [serviceId], references: [id])
  session   Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startTime])
  @@index([sessionId])
  @@index([serviceId])
}

model GuideUrl {
  id          String   @id @default(uuid())
  path        String
  title       String
  description String?
  url         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tipo        String?

  @@map("GuidesUrl")
}

model Instancia {
  id                     Int     @id @default(autoincrement())
  instanceName           String
  userId                 String
  instanceId             String
  instanceType           String? @default("Whatsapp")
  metaPhoneNumberId      String? @map("meta_phone_number_id")
  metaAccessToken        String? @map("meta_access_token")
  metaWabaId             String? @map("meta_waba_id")
  metaVerifyToken        String? @map("meta_verify_token")
  metaChannel            String? @default("whatsapp") @map("meta_channel")
  metaPageId             String? @map("meta_page_id")
  user                   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([metaPhoneNumberId])
  @@index([metaPageId])
  @@map("Instancias")
}

model Log {
  id        String   @id @default(uuid())
  level     String
  message   String
  context   String?
  timestamp DateTime @default(now())
}

model Manual {
  id          String   @id @default(uuid())
  name        String
  description String?
  url         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Module {
  id                     String       @id @default(uuid())
  label                  String
  route                  String
  icon                   String
  showInSidebar          Boolean?     @default(true)
  hiddenModuleToSelector Boolean?     @default(false)
  adminOnly              Boolean      @default(false)
  requiresPremium        Boolean      @default(false)
  allowedPlans           Plan[]
  order                  Int          @default(0)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  showOnlySelectedPlans  Boolean?     @default(false)
  customUrl              String?
  isContainer            Boolean      @default(false)
  moduleItems            ModuleItem[]
  userModules            UserModule[]
  navPreferences         UserNavPreference[]
}

model ModuleItem {
  id        String   @id @default(uuid())
  title     String
  url       String
  moduleId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  customUrl String?
  module    Module   @relation(fields: [moduleId], references: [id])
}

model Pausar {
  userId      String
  mensaje     String   @default("Fue un gusto ayudarte.")
  tipo        String   @default("abrir")
  baseurl     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  apikeyId    String
  instanciaId String
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CatalogConfig {
  id             String   @id @default(uuid())
  userId         String   @unique
  // Datos básicos
  whatsappNumber String?
  // Identidad visual
  bannerUrl      String?
  primaryColor   String?
  // Textos del hero
  headline       String?
  subheadline    String?
  // Redes sociales
  instagram      String?
  facebook       String?
  tiktok         String?
  // CTA / contacto
  ctaText        String?
  // Opciones de visualización
  showStock      Boolean  @default(true)
  showSku        Boolean  @default(false)
  // URL amigable
  slug           String?  @unique
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("catalog_config")
}

model Product {
  id              String           @id @default(uuid())
  userId          String
  title           String
  description     String?
  price           Decimal          @db.Decimal(65, 2)
  comparePrice    Decimal?         @db.Decimal(65, 2)
  sku             String?          @unique
  stock           Int              @default(0)
  isActive        Boolean          @default(true)
  images          String[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  category        String
  tags            String[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  cotizacionItems CotizacionItem[]

  @@index([userId, title])
}

model Cotizacion {
  id          String           @id @default(uuid())
  userId      String
  clientName  String
  clientPhone String?
  status      String           @default("borrador")
  notes       String?
  total       Decimal          @default(0) @db.Decimal(65, 2)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CotizacionItem[]

  @@index([userId, createdAt])
}

model CotizacionItem {
  id           String     @id @default(uuid())
  cotizacionId String
  productId    String?
  title        String
  unitPrice    Decimal    @db.Decimal(65, 2)
  quantity     Int        @default(1)
  subtotal     Decimal    @db.Decimal(65, 2)
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  product      Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model PromptInstance {
  id           Int     @id @default(autoincrement())
  instanceType String?
  description  String?
  content      String?
  instanceId   Int?
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PromptTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  content     String
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Registro {
  tipo         TipoRegistro
  fecha        DateTime?
  estado       String?
  resumen      String?
  lead         Boolean?
  nombre       String?
  detalles     String?
  meta         Json?
  sessionId    Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  id           Int           @id @default(autoincrement())
  session      Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  crmFollowUps CrmFollowUp[]

  @@index([tipo, fecha])
  @@index([sessionId])
}

model Reminders {
  id           String      @id @default(uuid())
  title        String
  description  String?
  time         String?
  repeatType   RepeatType? @default(NONE)
  repeatEvery  Int?
  endsAt       DateTime?
  instanceName String?
  serverUrl    String?
  apikey       String?
  userId       String?
  workflowId   String?
  remoteJid    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  pushName     String?
  isSchedule   Boolean?    @default(false)
  isCampaign   Boolean?    @default(false)
  order        Int         @default(0)
}

model Service {
  id           String        @id @default(uuid())
  userId       String
  name         String
  description  String?
  messageText  String
  order        Int           @default(0)
  createdAt    DateTime      @default(now())
  appointments Appointment[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  userId               String
  remoteJid            String
  pushName             String
  customName           String?                @map("custom_name")
  instanceId           String
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  status               Boolean
  id                   Int                    @id @default(autoincrement())
  seguimientos         String?                @default("")
  inactividad          String?                @default("")
  sessionDelay         String?
  flujos               String?                @default("")
  remoteJidAlt         String?
  agentDisabled        Boolean                @default(false)
  signatureEnabled     Boolean                @default(false) @map("signature_enabled")
  leadStatus           LeadStatus?
  leadStatusReason     String?                @map("lead_status_reason")
  leadStatusSourceHash String?                @map("lead_status_source_hash")
  leadStatusUpdatedAt  DateTime?              @map("lead_status_updated_at")
  serviceType          ServiceType?           @map("service_type")
  leadScore            Int?                   @map("lead_score")
  leadScoreReason      String?                @map("lead_score_reason")
  leadScoredAt         DateTime?              @map("lead_scored_at")
  assignedAdvisorId    String?                @map("assigned_advisor_id")
  adSource             Json?                  @map("ad_source")
  adSourceAt           DateTime?              @map("ad_source_at")
  appointments         Appointment[]
  registros            Registro[]
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionTags          SessionTag[]
  sessionTrigger       SessionTrigger?
  workflowStates       SessionWorkflowState[]
  crmFollowUps              CrmFollowUp[]
  financeTransactions       FinanceTransaction[]
  assignmentLogs            AssignmentLog[]
  internalNotes             InternalNote[]
  tasks                     Task[]
  leadStatusWorkflowHistory LeadStatusWorkflowExecution[]

  @@index([userId, remoteJid])
}

model InternalNote {
  id        Int      @id @default(autoincrement())
  sessionId Int
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([authorId])
  @@map("internal_notes")
}

model UserTaskType {
  id      Int    @id @default(autoincrement())
  ownerId String
  name    String
  order   Int    @default(0)

  @@unique([ownerId, name])
  @@index([ownerId])
  @@map("user_task_types")
}

model Task {
  id             Int       @id @default(autoincrement())
  ownerId        String
  assignedToId   String
  assignedToName String?
  sessionId      Int?
  contactName    String?
  contactJid     String?
  title          String
  type           String    @default("Seguimiento")
  dueDate        DateTime
  result         String?
  status         String    @default("pending")
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  session        Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([assignedToId])
  @@index([sessionId])
  @@index([dueDate])
  @@index([status])
  @@map("tasks")
}

model AssignmentLog {
  id         Int      @id @default(autoincrement())
  sessionId  Int
  advisorId  String?
  assignedBy String?
  action     String
  createdAt  DateTime @default(now())
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

model ChatConversationPreference {
  id         String    @id @default(cuid())
  userId     String
  remoteJid  String
  pinnedAt   DateTime?
  archivedAt DateTime?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, remoteJid])
  @@index([userId, pinnedAt])
  @@index([userId, archivedAt])
  @@index([userId, deletedAt])
}

model ChatMessage {
  id               BigInt   @id @default(autoincrement())
  userId           String
  instanceName     String
  instanceType     String?
  remoteJid        String
  remoteJidAlt     String?
  senderPn         String?
  messageId        String
  fromMe           Boolean  @default(false)
  pushName         String?
  messageType      String   @default("conversation")
  content          String?
  mediaUrl         String?
  raw              Json?
  messageTimestamp DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, instanceName, remoteJid, messageId, fromMe], map: "chat_messages_user_instance_jid_msg_from_unique")
  @@index([userId, remoteJid, messageTimestamp], map: "chat_messages_user_jid_ts_idx")
  @@index([userId, instanceName, messageTimestamp], map: "chat_messages_user_instance_ts_idx")
  @@map("chat_messages")
}

model ChatConversation {
  id                   BigInt    @id @default(autoincrement())
  userId               String
  instanceName         String
  instanceType         String?
  remoteJid            String
  remoteJidAlt         String?
  senderPn             String?
  pushName             String?
  lastMessageId        String?
  lastMessageFromMe    Boolean?
  lastMessageType      String?
  lastMessageContent   String?
  lastMessageMediaUrl  String?
  lastMessageRaw       Json?
  lastMessageTimestamp DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([userId, instanceName, remoteJid], map: "chat_conversations_user_instance_jid_unique")
  @@index([userId, lastMessageTimestamp], map: "chat_conversations_user_last_ts_idx")
  @@map("chat_conversations")
}

model SessionTag {
  sessionId Int
  tagId     Int
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([sessionId, tagId])
}

model SessionTrigger {
  id        Int      @id @default(autoincrement())
  time      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessionId Int      @unique
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SystemMessage {
  id         String        @id @default(uuid())
  message    String
  userId     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  title      String        @default("Sin título")
  typePrompt TypePromptAi? @default(TRAINING)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Tag {
  id          Int          @id @default(autoincrement())
  userId      String
  name        String
  slug        String
  color       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  order       Int          @default(0)
  sessionTags SessionTag[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId])
}

model Tool {
  id          String   @id @default(uuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("Tools")
}

model User {
  id                                 String                       @id @default(uuid())
  name                               String?
  email                              String                       @unique
  password                           String?
  emailVerified                      DateTime?
  image                              String?
  role                               Role                         @default(user)
  createdAt                          DateTime                     @default(now())
  updatedAt                          DateTime                     @updatedAt
  apiUrl                             String                       @default("https://api.openAI.co")
  company                            String                       @default("Empresa Demo")
  lat                                String                       @default("0.0000")
  lng                                String                       @default("0.0000")
  mapsUrl                            String                       @default("https://maps.google.com/?q=0,0")
  notificationNumber                 String                       @default("0000000000")
  openingPhrase                      String?                      @default("DEPRECATED")
  apiKeyId                           String?
  delSeguimiento                     String?                      @default("Estamos para servirle.") @map("del_seguimiento")
  advisorSignature                   String?                      @map("advisor_signature")
  plan                               Plan                         @default(basico)
  autoReactivate                     String?
  webhookUrl                         String?                      @default("https://n8npro.verzay.co/webhook")
  theme                              ThemeApp?                    @default(Default)
  muteAgentResponses                 Boolean                      @default(false)
  timezone                           String?
  meetingDuration                    Int?
  productLimit                       Int?
  onFacebook                         Boolean                      @default(false)
  onInstagram                        Boolean                      @default(false)
  aiModelId                          String?
  defaultAiModelId                   String?
  defaultProviderId                  String?
  delayTimeGpt                       String?                      @map("delayTimeGPT")
  meetingUrl                         String?
  minNoticeMinutes                   Int                          @default(0)
  preferredCurrencyCode              String                       @default("COP")
  tokenVersion                       Int                          @default(0)
  passPlainTxt                       String?                      @default("IA@verzay.1234")
  enabledSynthesizer                 Boolean                      @default(false)
  status                             Boolean                      @default(true)
  enabledCrmFollowUps                Boolean                      @default(false)
  enabledLeadStatusClassifier        Boolean                      @default(false)
  enableVoiceResponses               Boolean                      @default(false)
  voiceId                            String                       @default("nova")
  voiceModel                         String?                      @default("gpt-4o-mini-tts")
  voiceInstructions                  String?
  ttsProvider                        String?                      @default("openai")
  elevenLabsApiKey                   String?
  elevenLabsVoiceId                  String?
  googleSheetsWebhookUrl             String?                      @map("google_sheets_webhook_url")
  ownerId                            String?                      @map("owner_id")
  advisorRole                        String?                      @map("advisor_role")
  advisorAvailable                   Boolean                      @default(true) @map("advisor_available")
  autoAssignEnabled                  Boolean                      @default(false) @map("auto_assign_enabled")
  autoAssignMaxChats                 Int                          @default(5) @map("auto_assign_max_chats")
  accounts                           Account[]
  agentPrompts                       AgentPrompt[]
  publishedAgentPromptRevisions      AgentPromptRevision[]
  appointments                       Appointment[]
  chatConversationPreferences        ChatConversationPreference[]
  instancias                         Instancia[]
  pausar                             Pausar[]
  products                           Product[]
  catalogConfig                      CatalogConfig?
  cotizaciones                       Cotizacion[]
  promptInstances                    PromptInstance[]
  services                           Service[]
  sessions                           Session[]
  systemMessages                     SystemMessage[]
  tags                               Tag[]
  tools                              Tool[]
  apiKey                             ApiKey?                      @relation(fields: [apiKeyId], references: [id], onDelete: Restrict)
  defaultAiModel                     AiModel?                     @relation(fields: [defaultAiModelId], references: [id])
  userAvailability                   UserAvailability[]
  billing                            UserBilling?
  notificationContacts               UserNotificationContact[]
  userModules                        UserModule[]
  navPreferences                     UserNavPreference[]
  crmFollowUpRules                   CrmFollowUpRule[]
  crmFollowUps                       CrmFollowUp[]
  crmFollowUpMedia                   CrmFollowUpMedia[]
  weeklyReports                      WeeklyReport[]
  externalClientData                 ExternalClientData[]
  externalDataToolConfigs            ExternalDataToolConfig[]
  knowledgeBlocks                    KnowledgeBlock[]
  financeAccounts                    FinanceAccount[]
  financeAttachments                 FinanceAttachment[]
  financeCategories                  FinanceCategory[]
  financeTransactions                FinanceTransaction[]
  iaCredits                          IaCredit?
  reseller_reseller_reselleridToUser Reseller[]                   @relation("reseller_reselleridToUser")
  reseller_reseller_userIdToUser     Reseller[]                   @relation("reseller_userIdToUser")
  aiConfigs                          UserAiConfig[]
  owner                              User?                        @relation("AgentToOwner", fields: [ownerId], references: [id])
  agents                             User[]                       @relation("AgentToOwner")
  masterLinks                        LinkedAccount[]              @relation("MasterLinks")
  linkedTo                           LinkedAccount[]              @relation("LinkedTo")
  team                               Team?
  internalNotes                      InternalNote[]
  userNotes                          UserNote[]
  noteFolders                        NoteFolder[]
  leadStatusWorkflowConfigs          LeadStatusWorkflowConfig[]
  stageAutomations                   StageAutomation[]
  tagAutomations                     TagAutomation[]
  apptAutomations                    ApptAutomation[]
  taskTypeAutomations                TaskTypeAutomation[]
  reminderGroupAutomations           ReminderGroupAutomation[]
  affiliateProfile                   AffiliateProfile?
  referredBy                         AffiliateReferral?           @relation("ReferredBy")
  userSubscriptions                  UserSubscription[]
  resellerPlans                      ResellerPlan[]
  forms                              Form[]
  visualStyles                       UserVisualStyle[]
  userIntegrations                   UserIntegration[]
}

model UserVisualStyle {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserIntegration {
  id        String   @id @default(uuid())
  userId    String
  name      String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserNotificationContact {
  id        String   @id @default(uuid())
  userId    String
  phone     String
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CrmFollowUp {
  id                      String            @id @default(cuid())
  sessionId               Int
  userId                  String
  sourceReportId          Int?
  remoteJid               String
  instanceId              String
  leadStatusSnapshot      LeadStatus
  summarySnapshot         String?           @map("summary_snapshot")
  ruleKey                 String            @map("rule_key")
  sourceHash              String?           @map("source_hash")
  scheduledFor            DateTime          @map("scheduled_for")
  status                  CrmFollowUpStatus @default(PENDING)
  cancelOnReply           Boolean           @default(true) @map("cancel_on_reply")
  maxAttempts             Int               @default(2) @map("max_attempts")
  attemptCount            Int               @default(0) @map("attempt_count")
  generatedMessage        String?           @map("generated_message")
  errorReason             String?           @map("error_reason")
  lastProcessedAt         DateTime?         @map("last_processed_at")
  sentAt                  DateTime?         @map("sent_at")
  cancelledAt             DateTime?         @map("cancelled_at")
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  goalSnapshot            String?           @map("goal_snapshot")
  promptSnapshot          String?           @map("prompt_snapshot")
  fallbackMessageSnapshot String?           @map("fallback_message_snapshot")
  allowedWeekdaysSnapshot Int[]             @default([]) @map("allowed_weekdays_snapshot")
  sendStartTimeSnapshot   String?           @map("send_start_time_snapshot")
  sendEndTimeSnapshot     String?           @map("send_end_time_snapshot")
  session                 Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
