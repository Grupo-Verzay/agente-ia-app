# ============================================================
# VARIABLES DE ENTORNO — agente-ia-app
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# App
PORT=3000

# Auth (NextAuth)
AUTH_SECRET=                        # Mínimo 32 caracteres aleatorios
NEXTAUTH_URL=http://localhost:3000  # URL pública de la app
AUTH_RESEND_KEY=                    # API key de Resend (re_...)

# OAuth providers (opcionales)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Base de datos
DATABASE_URL=                       # postgresql://user:password@host:5432/dbname?schema=public

# Backend (Baileys / Evolution API)
BACKEND_URL=                        # URL del servicio backend (ej. https://api.tudominio.com)
BAILEYS_SECRET=                     # Secret compartido con el backend

# Claves internas de servicios
CRM_FOLLOW_UP_RUNNER_KEY=           # Clave de autenticación del runner CRM
CRON_SECRET=                        # Clave para proteger endpoints de cron jobs
OWNER_COMMANDS_KEY=                 # Secreto compartido con el backend para los endpoints /api/owner/* (Modo Dueño por WhatsApp)
SECRET_API_KEY=                     # API key de OpenAI usada en registros (sk-...)

# Seguimientos de prueba gratis (credenciales Evolution de respaldo)
# Se usan cuando el usuario en prueba no tiene un reseller con instancia propia.
FOLLOWUP_API_URL=                   # URL base de Evolution (ej. https://evoapi.ia-app.com)
FOLLOWUP_API_KEY=                   # API key de la instancia central
FOLLOWUP_INSTANCE_NAME=             # Nombre de la instancia central que envía los seguimientos

# Almacenamiento S3 / Minio
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=                        # Hostname sin protocolo (ej. medias3.tudominio.com)
S3_PUBLIC_URL=                      # URL pública con protocolo (ej. https://medias3.tudominio.com)
S3_BUCKET_NAME=verzay-media         # Nombre del bucket (default: verzay-media)

# AI — se requiere AL MENOS UNA de las siguientes claves de Google
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENAI_API_KEY=

# Google Service Account (para sincronización con Google Sheets)
# Pega aquí el contenido completo del archivo JSON descargado de Google Cloud Console
# (IAM & Admin → Service Accounts → tu cuenta → Keys → Add Key → JSON)
GOOGLE_SERVICE_ACCOUNT_JSON='{...}'

# Meta Cloud API (para instancias con WhatsApp Business Platform oficial)
META_VERIFY_TOKEN=                  # Token secreto para verificar el webhook de Meta (cualquier string aleatorio)

# Meta Embedded Signup (conexión automática / Coexistencia)
# Cuando tengas la app dedicada de Meta y la verificación de negocio, completa estos:
NEXT_PUBLIC_META_APP_ID=            # App ID de tu app de Meta (public — visible en cliente)
NEXT_PUBLIC_META_CONFIG_ID=         # ID de la configuración de Embedded Signup (public)
META_APP_SECRET=                    # App Secret (SOLO servidor — nunca exponer al cliente)
# Opcionales (tienen defaults):
NEXT_PUBLIC_META_GRAPH_VERSION=v21.0        # Versión de la Graph API en el cliente (default v21.0)
META_GRAPH_VERSION=v21.0                     # Versión de la Graph API en el servidor (default v21.0)
NEXT_PUBLIC_META_FEATURE_TYPE=whatsapp_business_app_onboarding  # Coexistencia (default). Vacío = Cloud API estándar

# OpenAI (opcional)
OPENAI_SYSTEM_API_KEY=              # API key de OpenAI para funciones del sistema (sk-...)

# AstraCalls (llamadas de voz por WhatsApp)
ASTRACALLS_URL=
ASTRACALLS_API_KEY=
