# Copiar a .env (o pegar como variables del Stack en Portainer) y rellenar.

# ── Modelos (API por uso) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...            # https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...     # https://console.anthropic.com/ (para Claude)

# ── Dominio (el subdominio que apunta al contenedor) ──────────────────
DOMAIN_CLIENT=https://ia.verzay.com
DOMAIN_SERVER=https://ia.verzay.com

# ── Acceso ────────────────────────────────────────────────────────────
# Deja true, crea TU usuario en el primer ingreso, y luego cámbialo a false
# y vuelve a desplegar para que nadie más pueda registrarse.
ALLOW_REGISTRATION=true

# ── Secretos (GENERAR valores aleatorios; no uses estos) ──────────────
# Genera cada uno con:  openssl rand -hex 32   (para IV usa: openssl rand -hex 16)
JWT_SECRET=CAMBIAR_32_bytes_hex
JWT_REFRESH_SECRET=CAMBIAR_32_bytes_hex
CREDS_KEY=CAMBIAR_32_bytes_hex_64_chars
CREDS_IV=CAMBIAR_16_bytes_hex_32_chars
MEILI_MASTER_KEY=CAMBIAR_aleatorio
POSTGRES_PASSWORD=CAMBIAR_aleatorio
